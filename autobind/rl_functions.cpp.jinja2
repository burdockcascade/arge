#include <vector>
#include <string>
#include <memory>
#include <raylib.h>
#include <quickjs.h>
#include "rl_structs.hpp"
#include "rl_functions.hpp"

namespace RaylibBindings {

{% for func in functions %}
    static JSValue js_{{ func.name }}(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv) noexcept {

        {% for p in func.params %}
        // Parameter: {{ p.name }} (Type: {{ p.type }})
        {% if p.is_struct %}
        // Handle struct parameters by retrieving the opaque pointer from the JS object
        auto *{{ p.name }}_ptr = static_cast<{{ p.clean_type }}*>(JS_GetOpaque2(ctx, argv[{{ p.index }}], js_{{ p.clean_type }}_class_id));
        if (!{{ p.name }}_ptr) return JS_EXCEPTION;
        {% if p.is_ptr %}
        // Pass the pointer directly for pointer parameters
        {{ p.type }} {{ p.name }} = {{ p.name }}_ptr;
        {% else %}
        // Dereference for non-pointer struct parameters
        {{ p.type }} {{ p.name }} = *{{ p.name }}_ptr;
        {% endif %}
        {% elif p.is_buffer %}
        // Handle buffer parameters by getting the ArrayBuffer data and size
        size_t {{ p.name }}_size = 0;
        uint8_t* {{ p.name }}_js_ptr = JS_GetArrayBuffer(ctx, &{{ p.name }}_size, argv[{{ p.index }}]);
        if (!{{ p.name }}_js_ptr) return JS_EXCEPTION;

        // Use a vector for automatic memory management (C++23)
        std::vector<uint8_t> {{ p.name }}_vec({{ p.name }}_js_ptr, {{ p.name }}_js_ptr + {{ p.name }}_size);
        const void *{{ p.name }} = {{ p.name }}_vec.data();
        {% elif p.type == "const char *" %}
        const char *{{ p.name }} = JS_ToCString(ctx, argv[{{ p.index }}]);
        if (!{{ p.name }}) return JS_EXCEPTION;
        {% elif  p.type == "char *" %}
        const char *{{ p.name }}_cstr = JS_ToCString(ctx, argv[{{ p.index }}]);
        if (!{{ p.name }}_cstr) return JS_EXCEPTION;
        char *{{ p.name }} = const_cast<char*>({{ p.name }}_cstr);
        {% else %}
        {% if p.direct_return %}
        // Direct return type (e.g., JS_ToBool)
        int {{ p.name }}_res = {{ p.from_js }}(ctx, argv[{{ p.index }}]);
        if ({{ p.name }}_res < 0) return JS_EXCEPTION;
        const auto {{ p.name }} = static_cast<{{ p.type }}>({{ p.name }}_res);
        {% else %}
        // Handle other parameter types by converting from JS to C++
        {{ p.cast }} {{ p.name }};
        if ({{ p.from_js }}(ctx, &{{ p.name }}, argv[{{ p.index }}])) return JS_EXCEPTION;
        {% endif %}
        {% endif %}

        {% endfor %}

        {% if func.is_ret_void %}
        // Call the Raylib function (no return value)
        {{ func.name }}({% for p in func.params %}{{ p.name }}{{ ", " if not loop.last }}{% endfor %});
        {% elif func.is_ret_struct %}
        // Call the Raylib function and store the struct result
        const auto result = {{ func.name }}({% for p in func.params %}{{ p.name }}{{ ", " if not loop.last }}{% endfor %});
        {% else %}
        // Call the Raylib function and store the result
        const auto result = {{ func.name }}({% for p in func.params %}{{ p.name }}{{ ", " if not loop.last }}{% endfor %});
        {% endif %}

        {% for p in func.params %}
        {% if p.type == "char *" %}
        // Free the C string after the function call
        JS_FreeCString(ctx, {{ p.name }}_cstr);
        {% endif %}
        {% endfor %}
        
        {% if func.is_ret_void %}
        // No return value
        return JS_UNDEFINED;
        {% elif func.is_ret_struct %}
        // Return a struct by wrapping it in a JS object
        return JS_New{{ func.clean_return_type }}(ctx, result);
        {% elif func.cast == "void *" %}
        // Return a void pointer as an integer (address)
        return JS_NewInt64(ctx, reinterpret_cast<int64_t>(result));
        {% else %}
        // Return a primitive type
        return {{ func.to_js }}(ctx, result);
        {% endif %}
    }

    {% endfor %}

    static constexpr JSCFunctionListEntry js_raylib_funcs[] = {
    {% for func in functions %}
        JS_CFUNC_DEF("{{ func.name }}", {{ func.params|length }}, js_{{ func.name }}),
    {% endfor %}
    };

    void InitAllFunctions(JSContext *ctx, JSValue ns) {
        JS_SetPropertyFunctionList(ctx, ns, js_raylib_funcs, {{ functions|length }});
    }

} // namespace RaylibBindings