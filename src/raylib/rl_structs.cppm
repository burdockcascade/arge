    // Alias: Texture2D maps to Texture ---
    JSValue JS_NewTexture2D(JSContext *ctx, Raylib::Texture data) {
        return JS_NewTexture(ctx, data);
    }


    void InitAllStructs(JSContext *ctx, JSValue ns) {
        InitVector2Binding(ctx, ns);
        InitVector3Binding(ctx, ns);
        InitVector4Binding(ctx, ns);
        InitMatrixBinding(ctx, ns);
        InitColorBinding(ctx, ns);
        InitRectangleBinding(ctx, ns);
        InitImageBinding(ctx, ns);
        InitTextureBinding(ctx, ns);
    }

} // namespace RaylibBindings